# Database
# Local: postgresql://user:password@localhost:5432/reservapp
# Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/reservapp?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/reservapp"

# Authentication
# Minimum 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET="your-jwt-secret-key-change-this-in-production"

# MercadoPago (Payment Gateway)
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-access-token"
MERCADOPAGO_PUBLIC_KEY="your-mercadopago-public-key"
MERCADOPAGO_WEBHOOK_SECRET="your-mercadopago-webhook-secret"

# Email Service (Resend)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# Redis (Session/Cache + BullMQ Queues)
# Local: redis://localhost:6379
# Upstash: rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
# Note: rediss:// (double s) enables TLS, required for Upstash
REDIS_URL="redis://localhost:6379"

# Cron Jobs
CRON_SECRET="your-random-cron-secret-change-this-in-production"

# Encryption (used for MercadoPago credentials stored in DB)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-character-hex-encryption-key-change-this-in-production"

# Error Monitoring (Sentry)
# Get DSN from: sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=""
# Auth token for source map uploads (build-time only)
# Get from: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="reservapp"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TZ="America/Santiago"
